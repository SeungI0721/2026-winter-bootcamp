<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2C2F35"/>
            <corners android:radius="16dp"/>
            <stroke android:width="2dp" android:color="#1E2024"/>
            <padding android:left="14dp" android:top="12dp" android:right="14dp" android:bottom="10dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#343943"/>
            <corners android:radius="16dp"/>
            <stroke android:width="2dp" android:color="#1E2024"/>
            <padding android:left="14dp" android:top="10dp" android:right="14dp" android:bottom="12dp"/>
        </shape>
    </item>
</selector>
