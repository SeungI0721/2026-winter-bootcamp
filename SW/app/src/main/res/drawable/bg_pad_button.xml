<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#30343A"/>
            <corners android:radius="22dp"/>
            <stroke android:width="2dp" android:color="#202226"/>
            <padding android:left="2dp" android:top="6dp" android:right="2dp" android:bottom="2dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3C4047"/>
            <corners android:radius="22dp"/>
            <stroke android:width="2dp" android:color="#202226"/>
            <padding android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="6dp"/>
        </shape>
    </item>
</selector>