<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize">

    <!-- 중앙 게임패드 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dpad"
        android:layout_width="320dp"
        android:layout_height="320dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Center STOP (큰 버튼) -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:text="■"
            android:textSize="32sp"
            android:textStyle="bold"
            android:background="@drawable/bg_stop_button"
            android:padding="0dp"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Up -->
        <Button
            android:id="@+id/btnForward"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:text="▲"
            android:textSize="28sp"
            android:textStyle="bold"
            android:background="@drawable/bg_pad_button"
            android:padding="0dp"
            android:stateListAnimator="@null"
            app:layout_constraintBottom_toTopOf="@id/btnStop"
            app:layout_constraintStart_toStartOf="@id/btnStop"
            app:layout_constraintEnd_toEndOf="@id/btnStop"
            android:layout_marginBottom="12dp" />

        <!-- Down -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:text="▼"
            android:textSize="28sp"
            android:textStyle="bold"
            android:background="@drawable/bg_pad_button"
            android:padding="0dp"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/btnStop"
            app:layout_constraintStart_toStartOf="@id/btnStop"
            app:layout_constraintEnd_toEndOf="@id/btnStop"
            android:layout_marginTop="12dp" />

        <!-- Left -->
        <Button
            android:id="@+id/btnLeft"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:text="◀"
            android:textSize="28sp"
            android:textStyle="bold"
            android:background="@drawable/bg_pad_button"
            android:padding="0dp"
            android:stateListAnimator="@null"
            app:layout_constraintEnd_toStartOf="@id/btnStop"
            app:layout_constraintTop_toTopOf="@id/btnStop"
            app:layout_constraintBottom_toBottomOf="@id/btnStop"
            android:layout_marginEnd="12dp" />

        <!-- Right -->
        <Button
            android:id="@+id/btnRight"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:text="▶"
            android:textSize="28sp"
            android:textStyle="bold"
            android:background="@drawable/bg_pad_button"
            android:padding="0dp"
            android:stateListAnimator="@null"
            app:layout_constraintStart_toEndOf="@id/btnStop"
            app:layout_constraintTop_toTopOf="@id/btnStop"
            app:layout_constraintBottom_toBottomOf="@id/btnStop"
            android:layout_marginStart="12dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 하단 바: CONNECT + MODE -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CONNECT"
            android:background="@drawable/bg_action_button"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="MODE: MANUAL"
            android:background="@drawable/bg_action_button"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
